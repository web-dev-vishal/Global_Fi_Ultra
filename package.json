{
  "name": "globalfi-ultra",
  "version": "1.0.0",
  "description": "Global-Fi Ultra — monorepo root (backend + frontend)",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "backend:start": "cd backend && node server.js",
    "backend:dev": "cd backend && nodemon server.js",
    "backend:install": "cd backend && npm install",
    "backend:test": "cd backend && NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "backend:lint": "cd backend && eslint src/**/*.js",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:install": "cd frontend && npm install",
    "install:all": "npm run backend:install && npm run frontend:install",
    "docker:build": "docker build -t globalfi-ultra .",
    "docker:run": "docker-compose up",
    "docker:stop": "docker-compose down"
  },
  "keywords": [
    "fintech",
    "financial-data",
    "orchestration",
    "real-time",
    "socket.io"
  ],
  "author": "Vishal Sanam",
  "license": "MIT"
}