{
  "name": "globalfi-ultra",
  "version": "1.0.0",
  "description": "Global-Fi Ultra — monorepo root (backend + frontend)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "backend:start": "cd backend && node server.js",
    "backend:dev": "cd backend && nodemon server.js",
    "backend:install": "cd backend && npm install",
    "backend:test": "cd backend && NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "backend:lint": "cd backend && eslint src/**/*.js",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:install": "cd frontend && npm install",
    "install:all": "npm run backend:install && npm run frontend:install",
    "docker:build": "docker build -t globalfi-ultra .",
    "docker:run": "docker-compose up",
    "docker:stop": "docker-compose down"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "axios": "^1.6.7",
    "axios-retry": "^4.0.0",
    "bcrypt": "^5.1.1",
    "big.js": "^6.2.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "groq-sdk": "^0.37.0",
    "helmet": "^7.1.0",
    "inquirer": "^13.2.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "ora": "^9.3.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "eslint": "^8.57.1",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "keywords": [
    "fintech",
    "financial-data",
    "orchestration",
    "real-time",
    "socket.io"
  ],
  "author": "Vishal Sanam",
  "license": "MIT"
}
